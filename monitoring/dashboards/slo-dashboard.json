{
  "dashboard": {
    "title": "SLO - Stack de Observabilidade",
    "uid": "slo-dashboard",
    "tags": ["slo", "sli", "sla"],
    "timezone": "browser",
    "editable": true,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "title": "📊 SLI - Disponibilidade dos Serviços",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "avg(up{namespace=\"monitoring\"})",
            "legendFormat": "Disponibilidade",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "red", "value": 0.95},
                {"color": "green", "value": 0.96}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "title": "📊 SLI - Uso de Memória (%)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"monitoring\"}) / sum(kube_pod_container_resource_requests{namespace=\"monitoring\", resource=\"memory\"})",
            "legendFormat": "Memória",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.85},
                {"color": "red", "value": 0.95}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "title": "📊 SLI - Uso de CPU (%)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"monitoring\"}[5m])) / sum(kube_pod_container_resource_requests{namespace=\"monitoring\", resource=\"cpu\"})",
            "legendFormat": "CPU",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.85},
                {"color": "red", "value": 0.95}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "title": "📈 SLI - Disponibilidade (histórico)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "avg(up{namespace=\"monitoring\"})",
            "legendFormat": "Disponibilidade",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 0.95}
              ]
            }
          }
        }
      },
      {
        "title": "📈 SLI - Memória (histórico)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"monitoring\"}) / sum(kube_pod_container_resource_requests{namespace=\"monitoring\", resource=\"memory\"})",
            "legendFormat": "Memória",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.85},
                {"color": "red", "value": 0.95}
              ]
            }
          }
        }
      },
      {
        "title": "📈 SLI - CPU (histórico)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"monitoring\"}[5m])) / sum(kube_pod_container_resource_requests{namespace=\"monitoring\", resource=\"cpu\"})",
            "legendFormat": "CPU",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.85},
                {"color": "red", "value": 0.95}
              ]
            }
          }
        }
      },
      {
        "title": "📋 SLA - Últimos Alertas SLO",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "targets": [
          {
            "expr": "ALERTS{alertname=~\"SLO_.*\"}",
            "legendFormat": "{{alertname}}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"alertname": "Alerta", "alertstate": "Estado", "severity": "Severidade"}}}
        ]
      }
    ]
  },
  "overwrite": true,
  "folderUid": "slo-folder"
}
