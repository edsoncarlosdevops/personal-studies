      {
        "title": "\ud83d\udcca SLI - Disponibilidade dos Servi\u00e7os",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "targets": [
          {
            "expr": "sum(kube_pod_status_ready{namespace=\"monitoring\", condition=\"true\"}) / count(kube_pod_status_ready{namespace=\"monitoring\", condition=\"true\"})",
            "legendFormat": "Disponibilidade",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 0.95
                },
                {
                  "color": "green",
                  "value": 0.96
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
