<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>App RDS - CRUD Usuarios</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            min-height: 100vh;
        }
        .container { max-width: 800px; margin: 0 auto; padding: 2rem; }
        header { text-align: center; padding: 2rem 0; border-bottom: 1px solid #1e293b; margin-bottom: 2rem; }
        header h1 { font-size: 2rem; background: linear-gradient(135deg, #60a5fa, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        header p { color: #94a3b8; margin-top: 0.5rem; }
        .status-bar {
            background: #1e293b; border-radius: 8px; padding: 1rem; margin-bottom: 2rem;
            display: flex; justify-content: space-between; align-items: center; font-size: 0.875rem;
        }
        .status-connected { color: #4ade80; }
        .status-disconnected { color: #f87171; }
        .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 0.5rem; }
        .status-dot.connected { background: #4ade80; }
        .status-dot.disconnected { background: #f87171; }
        .form-card { background: #1e293b; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
        .form-card h2 { font-size: 1.25rem; margin-bottom: 1rem; color: #60a5fa; }
        .form-group { display: flex; gap: 1rem; flex-wrap: wrap; }
        .form-group input {
            flex: 1; min-width: 200px; padding: 0.75rem 1rem; background: #0f172a;
            border: 1px solid #334155; border-radius: 8px; color: #e2e8f0; font-size: 0.9rem;
        }
        .form-group input:focus { outline: none; border-color: #60a5fa; }
        .form-group button {
            padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #60a5fa, #3b82f6);
            color: white; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer;
        }
        .form-group button:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(59,130,246,0.3); }
        .users-card { background: #1e293b; border-radius: 12px; padding: 1.5rem; }
        .users-card h2 { font-size: 1.25rem; margin-bottom: 1rem; color: #a78bfa; }
        .users-card .count { color: #94a3b8; font-size: 0.875rem; margin-bottom: 1rem; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 0.75rem 1rem; color: #94a3b8; font-size: 0.8rem; text-transform: uppercase; border-bottom: 1px solid #334155; }
        td { padding: 0.75rem 1rem; border-bottom: 1px solid #1e293b; font-size: 0.9rem; }
        tr:hover td { background: rgba(96,165,250,0.05); }
        .user-id { color: #64748b; font-family: monospace; }
        .user-email { color: #60a5fa; }
        .user-date { color: #94a3b8; font-size: 0.8rem; }
        .btn-delete { padding: 0.35rem 0.75rem; background: transparent; color: #f87171; border: 1px solid #f87171; border-radius: 6px; font-size: 0.8rem; cursor: pointer; }
        .btn-delete:hover { background: #f87171; color: white; }
        .empty-state { text-align: center; padding: 3rem; color: #64748b; }
        .empty-state p { font-size: 1.1rem; margin-bottom: 0.5rem; }
        .empty-state span { font-size: 2rem; }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>App RDS</h1>
            <p>CRUD de Usuarios - PostgreSQL + OpenTelemetry</p>
        </header>

        <div class="status-bar">
            <div>
                <% if (dbConnected) { %>
                    <span class="status-dot connected"></span>
                    <span class="status-connected">Banco conectado</span>
                <% } else { %>
                    <span class="status-dot disconnected"></span>
                    <span class="status-disconnected">Banco desconectado</span>
                <% } %>
            </div>
            <div style="color: #64748b; font-family: monospace; font-size: 0.8rem;">
                <%= dbHost %>/<%= dbName %>
            </div>
        </div>

        <div class="form-card">
            <h2>Novo Usuario</h2>
            <form action="/users" method="POST">
                <div class="form-group">
                    <input type="text" name="name" placeholder="Nome completo" required>
                    <input type="email" name="email" placeholder="Email" required>
                    <button type="submit">Adicionar</button>
                </div>
            </form>
        </div>

        <div class="users-card">
            <h2>Usuarios Cadastrados</h2>
            <div class="count"><%= users.length %> registro(s)</div>

            <% if (users.length === 0) { %>
                <div class="empty-state">
                    <span>Nenhum usuario cadastrado</span>
                    <p>Adicione seu primeiro usuario no formulario acima</p>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Criado em</th>
                            <th>Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(function(user) { %>
                            <tr>
                                <td class="user-id"><%= user.id %></td>
                                <td><%= user.name %></td>
                                <td class="user-email"><%= user.email %></td>
                                <td class="user-date"><%= new Date(user.created_at).toLocaleString('pt-BR') %></td>
                                <td>
                                    <form action="/api/users/<%= user.id %>/delete" method="POST" style="display:inline;">
                                        <button type="submit" class="btn-delete" onclick="return confirm('Deletar <%= user.name %>?')">Deletar</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>
