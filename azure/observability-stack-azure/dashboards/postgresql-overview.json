{
  "title": "PostgreSQL Overview",
  "uid": "postgresql-overview",
  "tags": ["postgresql", "observability"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "Server Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "Status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends{datname!~\"template.*|postgres\"})",
          "legendFormat": "Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "max(pg_database_size_bytes{datname!~\"template.*|postgres\"})",
          "legendFormat": "Size"
        }
      ],
      "unit": "bytes",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "(sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))) * 100",
          "legendFormat": "Cache Hit Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Transactions per Second",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[5m])",
          "legendFormat": "Commits"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[5m])",
          "legendFormat": "Rollbacks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks[5m])",
          "legendFormat": "Deadlocks"
        }
      ]
    },
    {
      "title": "Connections by Database",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 10 },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname!~\"template.*|postgres\"}",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Alerts",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "ALERTS{alertname=~\"PostgreSQL.*\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
